// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.245.2/containers/docker-existing-dockerfile
{
	"name": "Ubuntu Dev Container - On Fly Build",

	// Sets the run context to one level up instead of the .devcontainer folder.
	"context": "..",

	// Build settings (this dev container image is built on the fly)
	"dockerFile": "./Dockerfile",
	"build": { 
		// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
		"dockerFile": "./Dockerfile",

		//Arguments unique to build in dev container
		"args": { 
			"DEV_CONTAINER_PATH": ".devcontainer"
		}
	},

	// Specify user
	"containerUser": "ubuntu",

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		8085,
		11434
	],

	// Starting of supervisord must be managed here. CMD in the Docker file must be left as is
	// Ideally, this would occur under the init.sh script under ENTRYPOINT but doesn't initilise
	"postStartCommand": "supervisord -c /etc/supervisord.conf",

	//Prevent override of container specific commands
	"overrideCommand": false,

	// Uncomment when using a ptrace-based debugger like C++, Go, and Rust
	"runArgs": [
		"--gpus",
		"all",
		"--init"
	],

	"mounts": [ 
		"source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind", // Docker socket mount for docker-from-docker
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/ubuntu/.ssh,type=bind,consistency=cached",
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gcloud,target=/home/ubuntu/.config/gcloud,type=bind,consistency=cached",
		"source=vscode,target=/home/ubuntu/.vscode,type=volume",
		"source=ollama,target=/home/ubuntu/.ollama,type=volume",
		//"source=vscode-server,target=/home/mrdev/.vscode-server,type=volume",
		"source=bash_history,target=/home/ubuntu/.bash_history,type=volume",
		"source=local,target=/home/ubuntu/.local,type=volume",
		"source=pulumi,target=/home/ubuntu/.pulumi,type=volume"
	],

	// Uncomment to connect as a non-root user if you've added one. See https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "ubuntu",

	"settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
            "bash": {
                "path": "bash",
                "icon": "terminal-bash"
            }
		},
		"modelContextProtocol.servers": {
			"github": {
				"type": "http",
				"url": "https://api.githubcopilot.com/mcp/"
			}
		},
		"OLLAMA_MAX_LOADED_MODELS": "2",
		"OLLAMA_NUM_GPU": "1"
	}
}